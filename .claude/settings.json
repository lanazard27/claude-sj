{
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Write(**)",
      "Edit(**)",
      "Bash(*)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Bash(git reset --hard *)",
      "Bash(DROP *)",
      "Bash(mkfs *)",
      "Bash(dd if=* of=/dev/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/jeongsunjae/projects/sjh1/.claude/hooks/pre-bash-check.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/jeongsunjae/projects/sjh1/.claude/hooks/pre-modify-snapshot.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash /Users/jeongsunjae/projects/sjh1/.claude/hooks/pre-file-check.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 /Users/jeongsunjae/projects/sjh1/.claude/hooks/pre-security-check.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/jeongsunjae/projects/sjh1/.claude/hooks/pre-read-check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/jeongsunjae/projects/sjh1/.claude/hooks/audit-log.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash /Users/jeongsunjae/projects/sjh1/.claude/hooks/stats-tracker.sh",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/jeongsunjae/projects/sjh1/.claude/hooks/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/jeongsunjae/projects/sjh1/.claude/hooks/on-stop.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/jeongsunjae/projects/sjh1/.claude/hooks/on-session-end.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/jeongsunjae/projects/sjh1/.claude/hooks/on-pre-compact.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/jeongsunjae/projects/sjh1/.claude/hooks/on-subagent-stop.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
